{
    "openapi": "3.0.0",
    "info": {
        "title": "競馬API",
        "description": "競馬システムのAPIドキュメント",
        "contact": {
            "email": "support@example.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "APIサーバー"
        }
    ],
    "paths": {
        "/api/sample": {
            "get": {
                "tags": [
                    "サンプル"
                ],
                "summary": "サンプルデータの取得",
                "description": "サンプルエンドポイントの説明",
                "operationId": "f9e7ef46ce8e6826243b7ca8398926f3",
                "responses": {
                    "200": {
                        "description": "成功時のレスポンス",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Hello, World!"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2025-12-28T01:00:00Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "サンプル"
                ],
                "summary": "サンプルデータの作成",
                "description": "サンプルデータを作成します",
                "operationId": "7c54fec07e2187f13ece807419bfbec8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "テストデータ"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "説明文"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "作成成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Created successfully"
                                        },
                                        "data": {
                                            "properties": {
                                                "name": {
                                                    "type": "string"
                                                },
                                                "description": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "バリデーションエラー"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "サンプル",
            "description": "サンプル"
        }
    ]
}